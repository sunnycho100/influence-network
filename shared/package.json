{
  "name": "@alumni-graph/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types and utilities for Influence Network.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "default": "./dist/models.js"
    },
    "./messages": {
      "types": "./dist/messages.d.ts",
      "default": "./dist/messages.js"
    },
    "./warmness": {
      "types": "./dist/warmness.d.ts",
      "default": "./dist/warmness.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  }
}
